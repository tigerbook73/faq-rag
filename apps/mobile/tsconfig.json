{
  "compilerOptions": {
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "target": "ES2020",
    "lib": ["es2020"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "jsx": "react-native",
    "types": ["nativewind/types", "jest"],
    "paths": {
      "@/*": ["src/*"],
      "@faq-rag/shared": ["../../packages/shared/src/index.ts"]
    }
  },
  "extends": "expo/tsconfig.base"
}
