# --- API server location -------------------------------------------------
# Option A (recommended for local dev): leave both unset. The host/IP is
# auto-detected at runtime — via the browser's own address on
# `expo start --web`, or via Expo's dev-server info (Constants.expoConfig.hostUri)
# on a physical device/simulator connected through Metro (Expo Go / dev client).
# Only set the port if your backend (apps/web) isn't running on 3000:
# EXPO_PUBLIC_API_PORT=3000

# Option B: set the full URL explicitly. REQUIRED for production/EAS builds
# (there's no dev server to auto-detect from). Also useful locally to force a
# specific host — e.g. a tunnel/ngrok URL, or when auto-detection picks the
# wrong network interface.
# EXPO_PUBLIC_API_URL=http://192.168.3.202:3000
