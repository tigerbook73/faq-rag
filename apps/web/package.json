{
  "name": "@faq-rag/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -H 0.0.0.0",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "tsc --noEmit && eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write . | rg -v -F '(unchanged)' || true",
    "test": "jest",
    "e2e": "playwright test --grep-invert \"@real-api|@embed|@slow|@prod-smoke\"",
    "e2e:ui": "playwright test --ui-host=0.0.0.0 --grep-invert \"@real-api|@embed|@slow|@prod-smoke\"",
    "e2e:smoke": "playwright test --grep @smoke --grep-invert \"@real-api|@embed|@slow|@prod-smoke\"",
    "e2e:full": "playwright test --grep-invert \"@real-api|@embed|@slow|@prod-smoke\"",
    "e2e:real-api": "REAL_API=1 playwright test --grep \"@real-api|@embed\"",
    "e2e:embed": "REAL_API=1 playwright test --grep @embed",
    "e2e:remote": "playwright test --grep @smoke",
    "e2e:prod:smoke": "E2E_ENV=prod REAL_API=1 playwright test --grep @prod-smoke",
    "ingest": "bun scripts/ingest.ts",
    "seed:export": "bun scripts/seed.ts export",
    "seed:import": "bun scripts/seed.ts import",
    "seed:import:prod": "NODE_ENV=production bun scripts/seed.ts import",
    "seed:clear": "bun scripts/seed.ts clear",
    "seed:clear:prod": "NODE_ENV=production bun scripts/seed.ts clear",
    "vercel:env:pull": "bun scripts/vercel-env.ts pull",
    "vercel:env:push": "bun scripts/vercel-env.ts push",
    "vercel:env:delete": "bun scripts/vercel-env.ts delete",
    "hook:set": "bun scripts/setup-webhook.ts set",
    "hook:query": "bun scripts/setup-webhook.ts query",
    "hook:set:prod": "NODE_ENV=production bun scripts/setup-webhook.ts set",
    "hook:query:prod": "NODE_ENV=production bun scripts/setup-webhook.ts query",
    "prisma": "prisma",
    "db:migrate": "supabase migration up && prisma migrate deploy",
    "db:reset": "supabase db reset && prisma migrate deploy && pnpm hook:set",
    "deploy:remote": "supabase db push && prisma migrate deploy && pnpm hook:set:prod",
    "db:studio": "prisma studio",
    "sb:start": "supabase start",
    "sb:stop": "supabase stop",
    "sb:restart": "supabase stop && supabase start",
    "sb:status": "supabase status",
    "verify": "pnpm lint && pnpm format && pnpm build && pnpm test && pnpm e2e:full"
  },
  "dependencies": {
    "@faq-rag/shared": "workspace:*",
    "@anthropic-ai/sdk": "^0.90.0",
    "@base-ui/react": "^1.4.1",
    "@huggingface/transformers": "^4.1.0",
    "@langchain/textsplitters": "^1.0.1",
    "@prisma/client": "^5.22.0",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.105.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "eventsource-parser": "^3.0.8",
    "franc-min": "^6.2.0",
    "lucide-react": "^1.8.0",
    "mammoth": "^1.12.0",
    "next": "16.2.4",
    "next-themes": "^0.4.6",
    "openai": "^6.34.0",
    "pdf-parse": "^2.4.5",
    "pino": "^10.3.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-dropzone": "^15.0.0",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "sonner": "^2.0.7",
    "swr": "^2.4.1",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/pdf-parse": "^1.1.5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cac": "^7.0.0",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "jest": "^30.3.0",
    "lefthook": "^2.1.9",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "prisma": "^5.22.0",
    "shadcn": "^4.4.0",
    "supabase": "^2.98.2",
    "tailwindcss": "^4",
    "ts-jest": "^29.4.9",
    "typescript": "^5"
  }
}
