generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Document {
  id              String           @id @default(uuid())
  name            String
  mime            String
  contentHash     String           @map("content_hash")
  lang            String           @default("unknown")
  sizeBytes       Int              @map("size_bytes")
  status          String           @default("pending") // pending | uploaded | indexing | indexed | failed
  errorMsg        String?          @map("error_msg")
  totalChunks     Int?             @map("total_chunks")
  fileRef         String?          @map("file_path")
  embeddingModel  String           @default("bge-m3") @map("embedding_model")
  isBuiltIn       Boolean          @default(false) @map("is_built_in")
  createdAt       DateTime         @default(now()) @map("created_at")
  chunks          Chunk[]
  sampleQuestions SampleQuestion[]

  @@unique([contentHash, embeddingModel])
  @@index([status])
  @@map("documents")
}

model Chunk {
  id         String                       @id @default(uuid())
  documentId String                       @map("document_id")
  ord        Int
  content    String
  embedding  Unsupported("vector(1024)")?
  lang       String                       @default("unknown")
  createdAt  DateTime                     @default(now()) @map("created_at")
  document   Document                     @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@map("chunks")
}

model SampleQuestion {
  id         String   @id @default(uuid())
  documentId String   @map("document_id")
  question   String
  createdAt  DateTime @default(now()) @map("created_at")
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@map("sample_questions")
}

model Session {
  id        String           @id @default(uuid())
  title     String           @default("New Chat")
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")
  messages  SessionMessage[]

  @@index([updatedAt])
  @@map("sessions")
}

model SessionMessage {
  id        String   @id @default(uuid())
  sessionId String   @map("session_id")
  role      String
  content   String
  citations Json?
  createdAt DateTime @default(now()) @map("created_at")
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("session_messages")
}
