# =============================================================================
# FAQ RAG — Safe defaults (committed to git, no secrets)
# Prisma CLI reads this file directly — keep DATABASE_URL here
# Override anything in .env.development.local for local dev
# =============================================================================

# ── Database ── Prisma CLI reads this, not .env.development.local ────────────────────────
# Local Supabase CLI default credentials (safe to commit)
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
DIRECT_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# ── Mode ─────────────────────────────────────────────────────────────────────
EMBEDDING_PROVIDER=local
# LLM for translation + HyDE: "openai" → OpenAI/gpt-4o-mini, anything else → DeepSeek
LLM_PROVIDER=deepseek

# ── LLM model names (no API keys here) ───────────────────────────────────────
ANTHROPIC_MODEL=claude-sonnet-4-6
DEEPSEEK_MODEL=deepseek-chat
OPENAI_MODEL=gpt-4o-mini

# ── Embedding (local mode) ────────────────────────────────────────────────────
EMBEDDING_MODEL=Xenova/bge-m3
EMBEDDING_DIM=1024

# ── UI defaults ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_DEFAULT_PROVIDER=claude
NEXT_PUBLIC_APP_URL=http://localhost:3000
