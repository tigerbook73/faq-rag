# =============================================================================
# FAQ RAG — Environment Variables Reference
# =============================================================================
#
# File loading priority (Next.js):
#   .env.local  (git-ignored) → overrides → .env (committed)
#
# Prisma CLI reads .env only (not .env.local).
# Keep DATABASE_URL in both files to avoid surprises.
#
# For Vercel: paste each variable into
#   Project → Settings → Environment Variables
# =============================================================================

# ── Mode ─────────────────────────────────────────────────────────────────────
# local  → bge-m3 local model, no API key needed
# openai → OpenAI text-embedding-3-small, requires OPENAI_API_KEY
EMBEDDING_PROVIDER=local

# ── API Keys ── (never put real keys in .env) ─────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxx
DEEPSEEK_API_KEY=sk-xxx
OPENAI_API_KEY=sk-proj-xxx

# ── LLM model names ───────────────────────────────────────────────────────────
ANTHROPIC_MODEL=claude-sonnet-4-6
DEEPSEEK_MODEL=deepseek-chat
OPENAI_MODEL=gpt-4o-mini

# ── Embedding (local mode only) ───────────────────────────────────────────────
EMBEDDING_MODEL=Xenova/bge-m3
EMBEDDING_DIM=1024

# ── File uploads ──────────────────────────────────────────────────────────────
UPLOAD_DIR=./data/uploads

# ── Supabase ──────────────────────────────────────────────────────────────────
# Local dev  → http://127.0.0.1:54321  (pnpm supabase start)
# Production → https://xxx.supabase.co (Supabase Cloud dashboard)
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Browser-exposed — must match server-side values above
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# ── App ───────────────────────────────────────────────────────────────────────
# Local dev  → http://localhost:3000
# Production → https://xxx.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_DEFAULT_PROVIDER=claude

# ── Database ──────────────────────────────────────────────────────────────────
# Prisma CLI reads .env — keep DATABASE_URL here for `prisma studio` / `prisma db push`
#
# Local Supabase CLI (port 54322):
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
DIRECT_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
#
# Supabase Cloud:
# DATABASE_URL=postgresql://postgres.PROJECT-REF:PASSWORD@aws-x-region.pooler.supabase.com:6543/postgres?pgbouncer=true
# DIRECT_URL=postgresql://postgres.PROJECT-REF:PASSWORD@aws-x-region.pooler.supabase.com:6543/postgres
