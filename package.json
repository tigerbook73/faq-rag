{
  "name": "faq-rag",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@faq-rag/web",
    "dev:mobile": "turbo run start --filter=@faq-rag/mobile",
    "build": "turbo run build",
    "start:web": "turbo run start --filter=@faq-rag/web",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "format": "turbo run format",
    "typecheck": "turbo run typecheck",
    "e2e": "turbo run e2e",
    "sb:start": "pnpm --filter @faq-rag/web sb:start",
    "sb:stop": "pnpm --filter @faq-rag/web sb:stop",
    "sb:restart": "pnpm --filter @faq-rag/web sb:restart",
    "sb:status": "pnpm --filter @faq-rag/web sb:status",
    "verify": "turbo run verify"
  },
  "devDependencies": {
    "eslint": "^9.39.4",
    "lefthook": "^2.1.9",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "turbo": "^2.10.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "lefthook",
      "msw",
      "onnxruntime-node",
      "prisma",
      "protobufjs",
      "supabase"
    ],
    "ignoredBuiltDependencies": [
      "sharp",
      "supabase",
      "unrs-resolver"
    ],
    "patchedDependencies": {
      "react-native-css-interop@0.2.6": "patches/react-native-css-interop@0.2.6.patch"
    },
    "overrides": {
      "jest-environment-node": "30.4.1",
      "jest-mock": "30.4.1"
    }
  },
  "packageManager": "pnpm@10.11.0+sha512.6540583f41cc5f628eb3d9773ecee802f4f9ef9923cc45b69890fb47991d4b092964694ec3a4f738a420c918a333062c8b925d312f42e4f0c263eb603551f977",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "@tigerbook/check-env": "^0.2.5"
  }
}
